# Required: Anthropic API Key for Claude Agent SDK
ANTHROPIC_API_KEY="your-key-here"

# Required: OpenRouter API key for ADK agents
OPENROUTER_API_KEY="your-key-here"

# Optional: Model configuration (defaults shown)
# DEFAULT_MODEL="google/gemini-2.5-pro"
# CODING_MODEL="claude-sonnet-4-5-20250929" # Has to be Anthropic Model available in Claude Code
# REVIEW_MODEL="google/gemini-2.5-pro"

# Optional: OpenRouter configuration (defaults shown)
# OPENROUTER_API_BASE="https://openrouter.ai/api/v1"
# OR_SITE_URL="k-dense.ai"
# OR_APP_NAME="Agentic Data Scientist"

# Optional: Context7 API Key for enhanced documentation access
# CONTEXT7_API_KEY="your-key-here"

# Optional: Disable network access
# DISABLE_NETWORK_ACCESS=true

# Optional: Coding agent limits (prevent runaway context/cost)
# ADS_MAX_TURNS=80          # Max tool calls per coding stage (default: 80)
# ADS_MAX_BUDGET_USD=10.0   # Per-stage USD budget cap (default: 10.0)

# Optional: Enable context7 MCP server for library docs (disabled by default)
# ADS_CONTEXT7=true

# Optional: Instrumentation — per-call token/timing log (disabled if unset)
# ADS_USAGE_LOG=./usage.jsonl